\section{墙(无条件内核)}\label{sec:wall}
Act-I 的四条结果是一个整体:命题~\ref{prop:wall} 说观察者\emph{何时}失明;推论~\ref{cor:reff} 让阈值读取
真实(有效)分辨率;命题~\ref{prop:converse} 表明这是信道的性质、非某个估计器的;命题~\ref{prop:tax} 给它
定价;命题~\ref{prop:triple} 表明三个症状同时发作。全部无条件——不对对手如何铺展信号作任何假设。

\begin{proposition}[墙 / 相变]\label{prop:wall}
在比例区 $d,\dmon,n\to\infty$、$\dmon/d\to\alpha$、$\dmon/n\to\gamma$,恢复重叠
$\langle\hat u,u\rangle^2$ 对 $\rho<\rho^\star$ 严格为正,对 $\rho>\rho^\star$ 渐近重叠为零。阈值为
\begin{equation}\label{eq:rhostar}
\boxed{\ \rho^\star \;=\; 1-\frac{\sqrt{\dmon/n}}{s^2} \;=\; 1-\frac{\sqrt{\alpha/(n/d)}}{s^2}\ }
\end{equation}
且具体地,顶样本特征向量重叠服从 Baik--Ben~Arous--P\'ech\'e 律~\cite{bbp,paul,baiksilverstein,peche}
\begin{equation}\label{eq:overlap}
\langle\hat u,u\rangle^2 \;\xrightarrow{\ a.s.\ }\;
\begin{cases}
\dfrac{1-\gamma/\beta^2}{1+\gamma/\beta}, & \beta>\sqrt\gamma,\\[2mm]
0, & \beta\le\sqrt\gamma,
\end{cases}
\qquad \beta=s^2(1-\rho),\ \gamma=\dmon/n,
\end{equation}
故 $\langle\hat u,u\rangle^2>0 \iff s^2(1-\rho)>\sqrt{\dmon/n}\iff \rho<\rho^\star$。墙完全由几何决定:
零维 $\knull$、分辨率 $\alpha$、预算 $n/d$。它按\emph{裁剪}理解,$\rho^\star=\big[1-\sqrt\gamma/s^2\big]_0^1$:
当 $s^2\le\sqrt\gamma$ 时,即便 $\rho{=}0$ 已分辨尖峰也在边缘之下(起始即盲,$\rho^\star{=}0$);当
$s^2\gg\sqrt\gamma$ 时墙靠近 $1$(表~\ref{tab:regime})。它是悬崖而非斜坡,且随维度变尖锐:有限尺寸窗口
按 $d^{-1/3}$ 收窄(Tracy--Widom~\cite{tw,johnstone})。
\end{proposition}

\begin{table}[h]\centering\small
\begin{tabular}{@{}l c p{7.4cm}@{}}
\toprule
\multicolumn{1}{c}{\textbf{区}} & \multicolumn{1}{c}{\textbf{$\rho^\star$}} & \multicolumn{1}{c}{\textbf{含义}} \\ \midrule
$s^2\le\sqrt\gamma$(显眼度低于边缘) & $0$(裁剪) & 起始即盲:即便不隐藏信号也不可见 \\
$\sqrt\gamma<s^2$(有限墙) & $\in(0,1)$ & 在 $\rho^\star=1-\sqrt\gamma/s^2$ 处的真正悬崖 \\
$s^2\gg\sqrt\gamma$(响亮信号) & $\to1$ & 观察者一直有效,直到几乎全部能量被隐藏 \\
\bottomrule
\end{tabular}
\caption{裁剪墙 $\rho^\star=\big[1-\sqrt\gamma/s^2\big]_0^1$ 的三个区,按显眼度 $s^2$ 相对边缘 $\sqrt\gamma$
划分。只有中间区是可调悬崖。}
\label{tab:regime}
\end{table}

\noindent\emph{证明梗概。} 观察者的投影信号是 $\dmon$ 维的,总体协方差为 $I_{\dmon}+\beta\,\tilde u\tilde u^\top$,
$\tilde u$ 是 $u$ 的(单位)已分辨分量。顶样本特征值从 Marchenko--Pastur 体中脱离当且仅当 $\beta>\sqrt\gamma$
(BBP);边缘之下顶特征向量与 $\tilde u$ 渐近正交,故重叠与任何据其构造的判决规则都退化为随机。因
$\beta=s^2(1-\rho)$ 随 $\rho$ 递减,在 $s^2(1-\rho)=\sqrt\gamma$ 处越过边缘给出 \eqref{eq:rhostar}。尖锐
常数与下面的价格来自 \S\ref{sec:cgmt} 的单一不动点。\hfill$\square$

\begin{corollary}[有效秩形式:低分辨率\emph{抬高}墙]\label{cor:reff}
环境维数 $d$ 本身不出现在 $\rho^\star$ 中,因为 $\gamma=\alpha/(n/d)=\dmon/n$。决定墙的是\emph{被分辨}信道的
纵横比,由观察者实际分辨的协方差 $\Sigma_{\Smon}=P_{S}\Sigma P_{S}$ 的\emph{稳定秩}支配:
\begin{equation}\label{eq:reff}
r_{\mathrm{eff}}=\frac{\operatorname{tr}\Sigma_{\Smon}}{\|\Sigma_{\Smon}\|}\ \le\ \dmon,
\qquad \gamma_{\mathrm{eff}}=\frac{r_{\mathrm{eff}}}{n},
\qquad \rho^\star=1-\frac{\sqrt{\gamma_{\mathrm{eff}}}}{s^2}.
\end{equation}
方程~\eqref{eq:reff} \emph{仅}对\emph{平坦(白化)有效秩信道}精确:即 $\Sigma_{\Smon}$ 有 $r_{\mathrm{eff}}$
个相等非零特征值、其余为零,故在其值域内白化把检测约化为各向同性 $r_{\mathrm{eff}}$ 维尖峰模型,且
$\rho^\star=1-\sqrt{r_{\mathrm{eff}}/n}/s^2$ 带 BBP 常数成立。对\emph{一般}已分辨谱,\eqref{eq:reff} 只是
\emph{标度代理}:精确阈值是 $\Sigma_{\Smon}$ 的 deformed Marchenko--Pastur / Stieltjes 变换边缘~\cite{baisilverstein,baiyao},
$\sqrt{\gamma_{\mathrm{eff}}}=\sqrt{r_{\mathrm{eff}}/n}$ 是其首阶尺度(各向同性 $\sqrt{\dmon/n}$ 为上极值),
而非精确边缘。无论哪种情形,因 $r_{\mathrm{eff}}\le\dmon$,低秩已分辨信道($r_{\mathrm{eff}}\ll\dmon$)
\emph{降低}边缘、\emph{抬高} $\rho^\star$:不可检测区 $\{\rho>\rho^\star\}$ \emph{收缩}。在 $r_{\mathrm{eff}}\in\{50,100,200,300\}$
(于 $\dmon{=}300$)上验证(附录~\ref{app:repro})。
\end{corollary}

\begin{proposition}[逆定理:$\rho^\star$ 之外无一致检测]\label{prop:converse}
墙是信道的性质、非谱估计器的。对 $\rho>\rho^\star$(等价地 $\beta<\sqrt\gamma$),$n$ 个已分辨样本的干净律与
植入律相互毗连。在 $u\in S^{\dmon-1}$ 的均匀先验下,Bayes 似然比 $L_n$ 有有界二阶矩,
\begin{equation}\label{eq:secondmoment}
\E_0\!\big[L_n^2\big]\ \xrightarrow{\ \dmon,n\to\infty\ }\ \big(1-\beta^2/\gamma\big)^{-1/2}<\infty
\qquad(\beta<\sqrt\gamma),
\end{equation}
它在 $\rho\downarrow\rho^\star$ 时发散。故 $\chi^2$ 保持有界,总变差有界地远离 $1$,且对每个检验序列 $\phi_n$,
$\liminf_n\big(P_0(\phi_n{=}1)+P_1(\phi_n{=}0)\big)>0$:没有任何检验——任何判决规则、任何算力——能一致检出该
信号。检测阈值与恢复阈值重合。
\end{proposition}

\begin{proposition}[能量地板(严格)与价格(斜率假设下)]\label{prop:tax}
固定目标检测水平 $\tau>\tfrac12$。
\emph{(a) 地板与可行性上限。} 保持检测 AUC$\,\ge\tau$ 迫使已分辨\emph{比例}
$T\equiv1-\rho_{\max}\ge\beta(\tau)/s^2=c(\tau)\sqrt{\alpha/(n/d)}/s^2$($c(\tau)\ge1$),其地板随 $n/d\to0$
\emph{增长}。因 $T\le1$,这是一个\emph{可行性上限}:一旦地板超过 $1$($\beta(\tau)>s^2$),没有 $\rho$ 能保持
AUC$\,\ge\tau$——检测变得\emph{不可行}。(绝对已分辨能量 $\beta(\tau)=s^2T$ 发散;比例饱和于 $1$,随后可行性
上限起作用。)这部分仅由 \S\ref{sec:cgmt} 的不动点给出。
\emph{(b) 价格。} 若保留可检测足迹的代价 $\ell(T)$ 有斜率 $\ell'(T)\ge\kappa>0$,则在可行范围内价格满足
$\lmon=\ell(T)\ge\kappa\,c(\tau)\sqrt{\alpha/(n/d)}/s^2$,随地板增长;斜率 $\kappa$ 是领域特有的、经验校准。
\end{proposition}

\begin{proposition}[$\rho^\star$ 处的三重重合]\label{prop:triple}
在 $\rho^\star$ 处三个事件重合,皆为单一事件 $\beta_{\mathrm{sig}}=0$(信号序参量,即 $u$-重叠,触零):
(i) 恢复重叠消失(命题~\ref{prop:wall});(ii) 已分辨能量地板达到其极小 $\sqrt\gamma/s^2$,钉在边缘并随
$\gamma\to\infty$ 增长(命题~\ref{prop:tax});(iii) 尖峰的可检测(超临界)部分重新进入 Marchenko--Pastur 体,
其已分辨盈余消失而 $\rho^\star$ 已越入 $\Smon^\perp$。一个序参量,三个读数;这使得单一的"墙前止步"规则良置。
\end{proposition}

\begin{remark}[非光滑对手:重合作为次梯度成立]
对光滑隐藏谱,三个读数共享一个普通梯度。若对手\emph{非光滑}(如仅在某些输入上植入信号的条件规则,使
$\rho(\cdot)$ 分段),重合仍成立,梯度换成 Clarke 次微分:$0\in\partial_C\beta_{\mathrm{sig}}$ 在 $\rho^\star$
处钉住三者,因 $\beta_{\mathrm{sig}}$ 局部 Lipschitz 且该相变是 kink 而非跳变。真正有后果的非光滑性存在于
覆盖博弈(\S\ref{sec:open})。
\end{remark}


\section{一个与 BBP 一致的标量化}\label{sec:cgmt}
墙本身(命题~\ref{prop:wall})及其逆定理(命题~\ref{prop:converse})是\emph{严格}的:它们直接由尖峰协方差
BBP/Paul 定理~\cite{bbp,bgn,paul}与一个 Le~Cam 二阶矩~\cite{lecam,omh2013,omh2014}给出,无需下面的约化。约化所增添的,是一个
把墙、能量地板(命题~\ref{prop:tax}a)与三重重合(命题~\ref{prop:triple})打包为单一对象、并延续进博弈
(\S\ref{sec:game})的标量化序参量 $\beta_{\mathrm{sig}}$。我们经标准的凸高斯极小极大替换~\cite{cgmt}
(附录~\ref{app:cgmt})得到它,并\emph{作为一个对照 BBP 检验的标量化}呈现,而非自足的正则性证明:它的两个
非平凡输出——信号重叠与体值——在下面被证明与 BBP/Paul 重叠及 Marchenko--Pastur 边缘恒等重合,并与直接仿真
一致。严格性继承自 BBP;不动点是延伸它的记账。

\paragraph{估计器与原问题。}
记 $p\equiv\dmon$。在植入假设下,已分辨样本为 $z_i=g_i+\sqrt\beta\,\eta_i\,\tilde u$,
$g_i\sim\mathcal N(0,I_p)$,$\eta_i\sim\mathcal N(0,1)$,$\beta=s^2(1-\rho)$,$\tilde u$ 为单位已分辨方向;
堆叠 $Z=[z_1,\dots,z_n]=G+\sqrt\beta\,\tilde u\,\eta^\top$,$G\in\R^{p\times n}$ i.i.d.\ 标准高斯,
$\eta=(\eta_i)\in\R^n$。观察者方向是 $\hat\Sigma=\tfrac1n ZZ^\top$ 的顶特征向量,
\begin{equation}\label{eq:po}
\Phi=\max_{\|w\|=1}\tfrac1{\sqrt n}\|Z^\top w\|
=\max_{\|w\|=1}\ \max_{\|q\|\le1}\ \tfrac1{\sqrt n}\Big[w^\top G q+\sqrt\beta\,(w^\top\tilde u)(\eta^\top q)\Big],
\end{equation}
用 $\|Z^\top w\|=\max_{\|q\|\le1}q^\top Z^\top w$,$q\in\R^n$。

\paragraph{辅助问题。}
由 CGMT/Gordon 替换~\cite{cgmt,gordon},双线性高斯项 $w^\top G q$ 换成 $\|q\|\,g^\top w+\|w\|\,h^\top q$,其中
$g\sim\mathcal N(0,I_p)$,$h\sim\mathcal N(0,I_n)$ 独立:
\begin{equation}\label{eq:ao}
\phi=\max_{\|w\|=1}\ \max_{\|q\|\le1}\ \tfrac1{\sqrt n}\Big[\|q\|\,g^\top w+\|w\|\,h^\top q+\sqrt\beta\,(w^\top\tilde u)(\eta^\top q)\Big].
\end{equation}

\paragraph{标量化与不动点。}
在序参量 $\mu=\langle w,\tilde u\rangle$(信号重叠 $\beta_{\mathrm{sig}}$)、$r=\|q\|$、$a=\langle q,\hat\eta\rangle$
上标量化 AO,并优化冗余方向(附录~\ref{app:cgmt}),把 \eqref{eq:ao} 约化为一维势
\begin{equation}\label{eq:potential}
\Phi_{\mathrm{AO}}(\mu)=\sqrt{\gamma(1-\mu^2)}+\sqrt{1+\beta\mu^2}.
\end{equation}
驻点条件 $\Phi_{\mathrm{AO}}'(\mu)=0$ 给出 $\mu=0$,或平方后 $\beta^2(1-\mu^2)=\gamma(1+\beta\mu^2)$,即
\begin{equation}\label{eq:mu}
\boxed{\ \beta_{\mathrm{sig}}^2=\mu^{\star2}=\frac{\beta^2-\gamma}{\beta(\beta+\gamma)}\ }.
\end{equation}

\paragraph{$\beta_{\mathrm{sig}}=0$ 相变。}
展开 \eqref{eq:potential},$\Phi_{\mathrm{AO}}(\mu)=(\sqrt\gamma+1)+\tfrac{\mu^2}{2}(\beta-\sqrt\gamma)+O(\mu^4)$。
故 $\beta<\sqrt\gamma$ 时 $\mu=0$ 是唯一极大点,$\beta>\sqrt\gamma$ 时非平凡分支 \eqref{eq:mu} 分岔(叉式)。因此
\[
\beta_{\mathrm{sig}}=0 \iff \beta\le\sqrt\gamma \iff s^2(1-\rho)\le\sqrt{\dmon/n}\iff \rho\ge\rho^\star,
\]
恰为 \eqref{eq:rhostar},该相变在 $\mu$ 中连续但在 $\rho$ 中非解析——命题~\ref{prop:wall} 的尖锐性。

\paragraph{一致性检验。}
非平凡分支 \eqref{eq:mu} 恒等于 BBP/Paul 特征向量重叠 $\tfrac{1-\gamma/\beta^2}{1+\gamma/\beta}$,而
\eqref{eq:potential} 在 $\mu=0$ 处给出 $\Phi_{\mathrm{AO}}=1+\sqrt\gamma$,匹配 Marchenko--Pastur 边缘
$\sqrt{\lambda_{\max}}$。顶特征向量重叠的直接仿真在 $\gamma\in\{0.5,1,2\}$ 上匹配 \eqref{eq:mu}(在 $p=1200$
处最大绝对误差 $<0.04$;有限尺寸)。

\paragraph{从不动点到价格。}
检测 AUC 在 $\beta_{\mathrm{sig}}^2$ 中严格递增。保持 AUC$\ge\tau$ 即 $\mu^2\ge o(\tau)$;反演 \eqref{eq:mu}
(取 $m_\tau=o(\tau)$),
\begin{equation}\label{eq:betatau}
\beta(\tau)=\frac{m_\tau\gamma+\sqrt{m_\tau^2\gamma^2+4\gamma(1-m_\tau)}}{2(1-m_\tau)}\ \ge\ \sqrt\gamma,
\end{equation}
故保留已分辨能量地板为 $s^2(1-\rho_{\max})=\beta(\tau)$,给出 $T=\beta(\tau)/s^2\ge\sqrt\gamma/s^2$:这就是
命题~\ref{prop:tax}(a),$c(\tau)=\beta(\tau)/\sqrt\gamma\ge1$。当 $n/d\to0$($\gamma\to\infty$)时
$\beta(\tau)\to\infty$——在边缘附近($m_\tau\to0$)如 $\sqrt\gamma$,对固定 $\tau>\tfrac12$ 如
$\tfrac{m_\tau}{1-m_\tau}\gamma$。


\section{墙是一个博弈值}\label{sec:game}

\paragraph{归一化约定。} 为 \S\S\ref{sec:game}--\ref{sec:ext} 一次固定如下。环境维数 $d$;分辨率 $\alpha$,
已分辨维数 $\dmon=\alpha d$;预算比 $n/d$,样本数 $n$;纵横比 $\gamma=\dmon/n=\alpha/(n/d)$;价值子空间秩
$K$(被加载方向),比例 $\kappa=K/d$。对手在方向 $i$ 上放置每方向\emph{可见}尖峰能量 $h_i\ge0$(一个方差
盈余),总预算 $\sum_i h_i=s^2$;在价值子空间 $\mathcal T$ 上交付\emph{价值} $V=g\sum_{i\in\mathcal T}h_i$,
其中 $g$(无量纲)是每单位已分辨尖峰能量每方向的价值。故对平摊 $h_i=a$ 铺于 $K$ 个方向,$V=gKa$,即
$a=V/(gK)$。检测器在同一基准上比较:\emph{峰值}统计量 $\lambda_{\max}$(边缘 $\sqrt\gamma$);方向恢复
似然比(Le~Cam 二阶矩);以及聚合量 $\widehat T=\tfrac1n\sum_i\|P O_i\|^2$,其干净律均值等于所求和的维数、
方差为 $2(\dim)/n$。下面所有博弈值阈值都以这些单位陈述,且相互量纲一致。

至此隐藏方向 $u$ 与压力 $\rho$ 是\emph{外生}的。实际中两者都是被选择的:对手挑选如何把信号能量铺展到各方向
以最小化可检测性、同时仍交付价值,而观察者瞄准其固定分辨子空间去覆盖被加载方向。这是一个 Stackelberg 博弈,
墙成为其\emph{值}——不再是对强加 $\rho$ 的阈值,而是对手能隐藏的一个临界\emph{价值}(能力)。

\paragraph{设置。} 对手选择植入信号协方差谱 $\{h_i\ge0\}_{i\le d}$(方向 $i$ 上的尖峰能量),总预算
$\sum_i h_i=s^2$,须在一个 $K$ 维价值子空间 $\mathcal T$(每方向价值 $g$)上交付价值
$\operatorname{tr}(GH)=g\sum_{i\in\mathcal T}h_i\ge V$。观察者分辨一个 $\alpha d$ 维子空间(固定分辨率,
BBP 边缘 $\sqrt\gamma$,$\gamma=\alpha/(n/d)$),瞄准被加载方向。可检测性对谱(BBP)观察者是顶可见尖峰,
对最优观察者是似然比。命题~\ref{prop:game} 是本节的严格内核,在明确假设下证明;命题~\ref{prop:extensive}
与~\ref{prop:adapt} 随后放松亚广延假设 (A3) 与固定分辨假设 (A2),并以其区所允许的较弱严格度陈述。

\begin{proposition}[低秩、固定分辨隐藏下的博弈值]\label{prop:game}
\emph{假设:} \textup{(A1)} 植入信号加载 $K$ 个张成价值子空间 $\mathcal T$ 的\emph{标准正交}方向(正交尖峰);
\textup{(A2)} 观察者有\emph{固定}分辨率、瞄准以含 $\mathcal T$($K\le\alpha d$),边缘 $\sqrt\gamma$,
$\gamma=\alpha/(n/d)$;\textup{(A3)} $K=o(d)$(亚广延,故可见尖峰保持孤立——广延情形是命题~\ref{prop:extensive});
\textup{(A4)} 二阶(协方差)签名,由顶特征值(谱观察者)或似然比(最优观察者)读取。在 \textup{(A1)--(A4)} 下,
极小极大均衡是对手把价值\emph{平摊}铺展,$h_i=V/(gK)$($i\in\mathcal T$;每尖峰亚临界);漏洞不可检测当且仅当
交付的价值低于临界值,
\begin{equation}\label{eq:gameval}
\begin{aligned}
\text{谱(BBP)观察者:}&\quad V<V^\star_{\mathrm{spec}}=g\,K\sqrt{\gamma};\\
\text{最优观察者:}&\quad V<V^\star_{\mathrm{opt}}=g\sqrt{K\gamma}=V^\star_{\mathrm{spec}}/\sqrt K.
\end{aligned}
\end{equation}
故 $\rho$ 内生、墙是一个临界价值;$K=1$ 退回命题~\ref{prop:wall}。信号秩 $K$ 是隐藏者的资源——对峰值检测器
值一个因子 $K$、对最优检测器值 $\sqrt K$;观察者精巧度差距恰为 $\sqrt K$。
\end{proposition}

\noindent\emph{证明。} \emph{可行性与威胁模型。} 以每方向价值 $g$、总预算 $\sum_i h_i=s^2$ 在 $K$ 个方向上交付
价值 $V$ 可行当且仅当 $V\le gKs^2$(全部预算置于 $\mathcal T$);取 $V$ 在此范围。
\emph{检测优势(精确)。} 记 $P_0$ 为 $n$ 个已分辨样本的干净律,$P_H$ 为在 $K$-标架 $V=\{v_j\}$ 上带谱
$H=\{h_i\}$ 的植入律。对检验 $\phi:\text{data}\to\{0,1\}$,误差概率之和为
$R(\phi;H,V)=P_0(\phi{=}1)+P_H(\phi{=}0)$,由似然比检验最小化为 $R^\star=1-\mathrm{TV}(P_0,P_H)$;等价地,
检测优势 $\mathrm{adv}(\phi)=P_H(\phi{=}1)-P_0(\phi{=}1)$,最优为 $\mathrm{TV}(P_0,P_H)$。在 $(H,V)$ 的先验
$\pi$ 下,\emph{Bayes 风险}为 $R_\pi=\inf_\phi\E_{\pi}R(\phi;H,V)$,\emph{minimax 风险}为
$R_{\mathrm{mm}}=\inf_\phi\sup_{H,V}R(\phi;H,V)\ge R_\pi$。博弈值是不可区分与可检测之间的阈值,
\[
V^\star=\sup\{V:\ R_{\mathrm{mm}}\to1\}
=\inf\big\{V:\ \sup_{\phi}\ \mathrm{adv}(\phi)\ \text{as }d\to\infty\ \text{有界地远离 }0\big\},
\]
即对手能交付、同时迫使每个检验退化为随机($R_{\mathrm{mm}}\to1$,渐近不可区分)的\emph{最大}价值,等价地
某检验获得正优势的\emph{最小}价值。(两集是互补的上/下集,因可检测性对交付值单调,故公共边界良定义。)\emph{方向。} \emph{已知固定}
标架平凡可检测(固定方向似然比二阶矩发散),故隐藏者\emph{随机化}:从 $K$-标架上的 Haar 先验 $\pi$ 抽取 $V$
(观察者未知)。把 $P_H$ 对 $\pi$ 平均得混合 $\bar P_H$;由 TV 的凸性,
$\mathrm{TV}(P_0,\bar P_H)\le\E_V\mathrm{TV}(P_0,P_H)$,且
$\mathrm{TV}(P_0,\bar P_H)^2\le\tfrac14\big(\E_0[\bar L^2]-1\big)$,$\bar L=d\bar P_H/dP_0$ 为混合似然比。
故一个\emph{有界混合二阶矩} $\E_0[\bar L^2]=O(1)$ 保证 $\mathrm{TV}(P_0,\bar P_H)\to0$、从而 Bayes 风险
$R_\pi\to1$;因 $R_{\mathrm{mm}}\ge R_\pi$,该 Haar 先验计算\emph{下界 minimax 风险}(最难先验证书)。
观察者分辨率由 (A2) 固定并瞄准 $\mathcal T$,故看到 $K$ 个尖峰;其最佳谱统计量是 $\lambda_{\max}(H)$,最佳
检验是似然比。
\emph{谱支。} 对手在 $\sum_i h_i=s^2$ 与 $g\sum_{\mathcal T}h_i\ge V$ 下最小化 $\lambda_{\max}(H)$;任务约束
起作用时最小峰值为 $\max\{V/(gK),\,s^2/d\}=V/(gK)$,由平摊达到,且由 BBP,顶样本特征值从体中脱离当且仅当
可见尖峰超过边缘,$V/(gK)>\sqrt\gamma$;故 $V^\star_{\mathrm{spec}}=gK\sqrt\gamma$。
\emph{最优支。} 我们在均匀标架先验下计算 Bayes 二阶矩 $\E_0[L_n^2]$,再在三个 $K$-区读出阈值。
\emph{二阶矩。} (a)~\emph{因式分解。} 对每方向能量 $h_j$ 的正交尖峰,逐样本似然比在 $j$ 上因式分解,由命题
~\ref{prop:converse} 的单尖峰计算,$\E_0[L_n^2]=\prod_{j=1}^{K}\big(1-h_j^2/\gamma\big)^{-1/2}$。
(b)~\emph{标架解耦。} 对 $L_n$ 平方并平均引入两个独立 Haar 标架 $\{v_j\},\{v'_{j'}\}$;交叉项只依赖对角外
的 Gram 重叠 $\langle v_j,v'_{j'}\rangle=O(1/\sqrt d)$,故对角配对主导鞍点、乘积形式对方向平均比渐近成立
(标准多尖峰论证,附录~\ref{app:multispike};参见~\cite{bgn,pwbm})。
\emph{哪个假设控制哪一步。} 假设 A1(正交尖峰)使因式分解 (a) 在\emph{每个 $K$ 都精确};比例极限 $d\to\infty$ 使
单个标架交叉项为 $O(1/\sqrt d)$、其亚广延聚合使 (b) 成立;假设 A3($K=o(d)$)控制 (o2) 的小尖峰展开余项。故 A1
永不失效,而 (b) 与 A3 正是广延区 (o3) 里破裂的东西。
\emph{$K$ 的三个区。}
\begin{itemize}\setlength{\itemsep}{1pt}
\item[(o1)] \emph{固定 $K=O(1)$。} $\E_0[L_n^2]=\prod_j(1-h_j^2/\gamma)^{-1/2}$ 有限当且仅当每尖峰亚临界
($h_j<\sqrt\gamma$);有界二阶矩给出毗连(Le~Cam),故无一致检验。平摊最优给出 $V<g\sqrt{K\gamma}$(见下)。
\item[(o2)] \emph{增长 $K=o(d)$(假设 A3)。} 平摊 $h_j=a$,在墙处 $a=\Theta(\sqrt{\gamma/K})\to0$ 使
$Ka^2=\Theta(\gamma)$,展开 $\ln\E_0[L_n^2]=-\tfrac K2\ln(1-a^2/\gamma)=\tfrac{Ka^2}{2\gamma}+O(Ka^4/\gamma^2)$;
$a^4$ 余项恰因 $K=o(d)$ 为 $o(1)$,故 $\E_0[L_n^2]\to e^{Ka^2/2\gamma}<\infty$ 当且仅当 $Ka^2<\gamma$。阈值
$V^\star_{\mathrm{opt}}=g\sqrt{K\gamma}$ 在此区始终成立。
\item[(o3)] \emph{广延 $K=\Theta(d)$。} 尖峰不再孤立:$a=\Theta(\sqrt{\gamma/K})$ 使
$Ka^4/\gamma^2=\Theta(1/K)\cdot K=\Theta(1)$ 不再可忽略,(o2) 的乘积/展开失效,可见谱变为一个体(自由卷积)。
此区在命题~\ref{prop:game} 中出界;它被单独、且仅在标度层级,在命题~\ref{prop:extensive} 中处理。
\end{itemize}
\emph{外层问题(对手)。} 最小化可检测性即最小化 $\E_0[L_n^2]$,亦即在 $g\sum_{\mathcal T}h_i\ge V$ 下最小化
$\sum_i h_i^2$(指数中单调);目标凸、约束线性,故极小点是平摊 $h_i=V/(gK)$,给出 $\sum h_i^2=Ka^2=V^2/(g^2K)$,
不可检测当且仅当 $V^2/(g^2K)<\gamma$,即 $V<g\sqrt{K\gamma}=V^\star_{\mathrm{opt}}$。最佳响应动力学收敛到
平摊均衡;仿真(图~\ref{fig:game})显示谱坍塌在 $V^\star_{\mathrm{spec}}$、聚合坍塌在 $V^\star_{\mathrm{opt}}$。
\hfill$\square$

\begin{remark}[均衡值 vs 到达它的动力学]
命题~\ref{prop:game} 给出均衡;优化器\emph{如何}到达它是代理与 token 运行中所见的双稳态(\S\ref{sec:numerics})。
因可检测性是悬崖,对手的"价值减可检测性"目标在墙附近是一个双阱,故隐藏是一个亚稳态势垒穿越——策略跃过而非
停在墙上。博弈固定值,穿越固定动力学。
\end{remark}


\section{延伸与猜想区}\label{sec:ext}
以下结果离开命题~\ref{prop:game} 的严格角落,以其区所允许的较弱严格度陈述——一个标度界(命题
~\ref{prop:extensive},放松亚广延 A3)与一个条件性坍塌(命题~\ref{prop:adapt},放松固定分辨 A2)。它们
勾勒博弈值随假设破裂而去往何处;精确广延值与一般自适应鞍点仍开放(\S\ref{sec:open})。此处所有阈值使用
\S\ref{sec:game} 之前所述的归一化约定。

\begin{proposition}[广延任务自败:铺展优势饱和]\label{prop:extensive}
用 \S\ref{sec:game} 的归一化:价值 $V=g\,K\,a$ 由每方向可见能量 $a$ 的平摊尖峰铺于 $K$ 个被瞄准、已分辨方向
交付($g$ 为价值密度)。非瞄准观察者对其全部 $\dmon=\alpha d$ 个已分辨坐标构造已分辨二阶矩
$\widehat T=\tfrac1n\sum_{i=1}^{n}\|P_{\mathrm{mon}}O_i\|^2$,干净律矩为
\[
\E_0[\widehat T]=\dmon=\alpha d,\qquad \mathrm{Var}_0(\widehat T)=\frac{2\dmon}{n}=2\gamma,
\qquad \sigma_T=\sqrt{2\gamma},
\]
($\gamma=\dmon/n$)。平摊尖峰把均值抬高 $\Delta_T=\sum_{\mathcal T}a=Ka=V/g$,\emph{与如何铺展无关}。
$\widehat T$ 检测要求 $\Delta_T\gtrsim\sigma_T$,即
\begin{equation}\label{eq:extcap}
\frac{V}{g}\ \gtrsim\ \sqrt{2\gamma}
\qquad\Longrightarrow\qquad
V^\star_{\mathrm{ext}}=\Theta\!\big(g\sqrt{\gamma}\big)=\Theta\!\Big(g\sqrt{\alpha/(n/d)}\Big),
\end{equation}
\emph{与 $K$ 无关}:均值移位 $\Delta_T=V/g$ 不依赖铺展,故加宽信号对聚合统计量毫无收益。于是峰值观察者优势
$V^\star_{\mathrm{spec}}=gK\sqrt\gamma$(在 $K$ 中线性)与恢复优势 $V^\star_{\mathrm{opt}}=g\sqrt{K\gamma}$
(命题~\ref{prop:game} 的 $\sqrt K$ 差距)都\emph{饱和}:一个平凡聚合检测器把可藏价值 cap 在单方向尺度
$\Theta(g\sqrt\gamma)$,已在 $K=\Theta(1)$ 处达到(此处 $gK\sqrt\gamma$ 与 $g\sqrt\gamma$ 相遇)。仿真确认
$K$-无关与 $\sqrt\gamma$ 标度:测得 cap 在 $K\in\{1,\dots,64\}$ 上平坦、随 $\sqrt{\alpha/(n/d)}$ 标度,
$O(1)$ 常数在 AUC$=0.75$ 处 $\approx4.7$(图~\ref{fig:free},附录~\ref{app:repro})。
\end{proposition}

\begin{remark}[为何 cap 在 $\alpha$ 中\emph{增长}:无瞄准的覆盖是浪费]\label{rem:alphamono}
cap \eqref{eq:extcap} 按 $\sqrt\gamma=\sqrt{\alpha/(n/d)}$ 标度,故在覆盖 $\alpha$ 中\emph{增长}——反直觉地,
更多覆盖使一个\emph{非瞄准}聚合检测器\emph{更差}。原因是维度上的:未瞄准的迹对全部 $\dmon=\alpha d$ 个已分辨
坐标求和,故其零噪声地板 $\sigma_T=\sqrt{2\dmon/n}=\sqrt{2\gamma}$ 随 $\sqrt\alpha$ 增长;而被迫信号
$\Delta_T=V/g$ 固定,故被\emph{稀释}到额外的未加载坐标上。花在信号不占据方向上的覆盖是纯粹的额外方差。这正是
瞄准所移除的惩罚:命题~\ref{prop:adapt} 把求和限制在 $K_{\mathrm{pool}}$ 个被加载维度,把 $\sqrt{2\gamma}$
换成 $\sqrt{2K_{\mathrm{pool}}/n}$、把 cap 的 $\sqrt\alpha$ 增长换成小得多的 $\sqrt{K_{\mathrm{pool}}/n}$。
故两个命题是同一陈述的两面:对聚合统计量,\emph{看哪里}压倒\emph{看多少}——无瞄准的原始覆盖抬高噪声地板,
而瞄准使之坍塌。
\end{remark}

\begin{remark}[范围与一处更正]\label{rem:extscope}
命题~\ref{prop:extensive} 是标度界(层级 S):迹是一个特定检验,从上方 cap 隐藏者,而峰值检测器从另一方向
cap($V^\star_{\mathrm{spec}}$);精确最优观察者值是 Marchenko--Pastur 体与可见谱的自由乘性卷积~\cite{freeprob},居于两者
之间,钉住它是 \S\ref{sec:open} 开放问题的一部分。早期草稿的形式 $\Theta(g/\sqrt{\alpha\,n/d})$ 差一个因子
$\alpha$;\eqref{eq:extcap} 是更正后、与归一化一致、与仿真匹配的标度。
\end{remark}

\begin{proposition}[自适应分辨坍塌墙]\label{prop:adapt}
\emph{假设:} \textup{(B1)} 价值算子 $G$(从而价值子空间 $\mathcal T$,$\dim K_{\mathrm{pool}}$)是\emph{公开}的
——观察者知道价值在何处收集;\textup{(B2)} 观察者可\emph{自适应}其分辨率,把其 $\alpha d$ 维算子瞄准任意子空间,
且 $K_{\mathrm{pool}}\le\alpha d$ 故能覆盖 $\mathcal T$;\textup{(B3)} 它在瞄准子空间上使用总方差(迹)统计量
$\widehat T=\tfrac1n\sum_i\|P_{\mathcal T}O_i\|^2$;\textup{(B4)} 价值以任务子空间方差交付,
$\operatorname{tr}(GH)=g\cdot(\mathcal T\text{ 中方差})$,故它是\emph{被迫且不可约}的。在 \textup{(B1)--(B4)} 下,
交付价值 $V$ 迫使 $\mathcal T$ \emph{内}的已分辨方差 $V/g$(B4),而瞄准的聚合量直接测量它。推导镜像命题
~\ref{prop:extensive},只是迹现在取在\emph{被瞄准}的 $K_{\mathrm{pool}}$ 维子空间 $\mathcal T$ 上而非全部
$\dmon$:令 $\widehat T_{\mathcal T}=\tfrac1n\sum_i\|P_{\mathcal T}O_i\|^2$,
\[
\E_0[\widehat T_{\mathcal T}]=K_{\mathrm{pool}},\qquad
\mathrm{Var}_0(\widehat T_{\mathcal T})=\frac{2K_{\mathrm{pool}}}{n},\qquad
\sigma=\sqrt{2K_{\mathrm{pool}}/n},
\]
而被迫信号把均值抬高 $\Delta_T=V/g$(B4,铺展不变)。检测要求 $\Delta_T\gtrsim\sigma$,即
$V/g\gtrsim\sqrt{2K_{\mathrm{pool}}/n}$,故
\begin{equation}\label{eq:adaptval}
V^\star_{\mathrm{adapt}}=\Theta\!\Big(g\sqrt{K_{\mathrm{pool}}/n}\Big).
\end{equation}
这比命题~\ref{prop:extensive} 的非瞄准 cap $\Theta(g\sqrt\gamma)$ 低一个因子
$\sqrt{\dmon/K_{\mathrm{pool}}}=\sqrt{\alpha d/K_{\mathrm{pool}}}$(瞄准把所求和维度从 $\dmon$ 缩到
$K_{\mathrm{pool}}$、故噪声地板从 $\sqrt{2\gamma}$ 缩到 $\sqrt{2K_{\mathrm{pool}}/n}$),并比固定观察者博弈值
$g\sqrt{K\gamma}$(\eqref{eq:gameval})低一个因子 $\sqrt{\alpha d}$。命题~\ref{prop:game}、\ref{prop:extensive}
的铺展优势\emph{蒸发}:对手对固定观察者所藏,瞄准观察者抓住(图~\ref{fig:adapt}),且样本足够时
$V^\star_{\mathrm{adapt}}\to0$。墙只在观察者违反 (B1)--(B2) 时保护隐藏者——它无法瞄准(私有/未知价值结构)
或缺乏预算覆盖 $\mathcal T$($K_{\mathrm{pool}}>\dmon$,开放的覆盖区)。
\end{proposition}

\begin{remark}[动力学一致性(两时标;条件性,非承重)]\label{prop:dynamics}
博弈值固定均衡;以下是一个\emph{一致性检验},说明一个自然训练动力学到达它,而非核心定理——它是条件性的,我们
如此标注。把训练回路建模为两时标随机逼近~\cite{borkar},含一个\emph{快}观察者变量 $\hat D_k$(其可检测性
估计)与一个\emph{慢}策略变量 $\rho_k$(涌现隐藏),步长 $a_k$(慢)、$b_k$(快),$\sum a_k=\sum b_k=\infty$,
$\sum(a_k^2{+}b_k^2)<\infty$,$a_k/b_k\to0$。假设 \textup{(D1)} 快递归跟踪其驻点,$\hat D_k\to D^\star(\rho)$,
即当前 $\rho$ 处的 BBP 可检测性(观察者在策略更新之间达到均衡);\textup{(D2)} 慢目标
$J(\rho)=\lambda\big(1-D^\star(\rho)\big)-c\,\rho$(逃避奖励减隐藏代价)有有界梯度噪声。则慢递归是 $J$ 的
噪声梯度流,$J$ 为其 Lyapunov 函数,$\rho_k$ 几乎必然收敛到 $J$ 的驻点集——命题~\ref{prop:game} 的均衡,在
隐藏盆中 $\rho_\infty=\rho^\star$。因 $D^\star$ 是\emph{尖锐}墙,$J$ 是双阱,均衡由一个\emph{亚稳态势垒穿越}
(Kramers)到达:涌现隐藏\emph{溢入}零信道,呈延迟、双稳态的相变,而非光滑漂移(图~\ref{fig:dynamics})。这
假设了时标分离 (D1) 与光滑慢目标 (D2);PPO 离散、非平稳 Markov 动力学的收敛证明——观察者与策略无干净时标
分离地共适应——出界并留开。它所买到的是\emph{机制}(势垒穿越而非光滑漂移),对博弈值的一致性检验,而非承重
结果。
\end{remark}


\section{悬崖判据}\label{sec:cliff}
\S\ref{sec:wall} 的墙之所以尖锐,是因为足迹是二阶的(注~\ref{rem:whyspike})。现在把这一点精确化:横跨这族
"策略 vs 检查"博弈——\S\ref{sec:apps} 的两个安全实例、奖励模型过优化、学习分类器——部分信道几何是通用的,但
\emph{尖锐性}不是。它由信号的阶数决定。

\begin{theorem}[部分信道族的 BBP-悬崖判据]\label{th:dich}
在部分信道模型 \eqref{eq:model} 内,固定分辨率 $\alpha$、预算 $n/d$、显眼度 $s$,并令已分辨分布的植入扰动为
秩一。则压力 $\rho$ 中的检测/恢复相变由扰动的\emph{阶数}决定:
\begin{itemize}\setlength{\itemsep}{1pt}
\item[(i)] \emph{二阶 $\Rightarrow$ 悬崖。} 若扰动是\emph{协方差}尖峰(沿 $u$ 的方差盈余 $s^2(1-\rho)$),
恢复是尖峰协方差问题,经历命题~\ref{prop:wall}--\ref{prop:converse} 的 BBP 相变:一个在 $\rho$ 中非解析的
阈值 $\rho^\star$,其上重叠为零且 Le~Cam 毗连,随 $d^{-1/3}$ 变尖锐。
\item[(ii)] \emph{一阶 $\Rightarrow$ 斜坡。} 若扰动是\emph{均值}移位(已分辨均值 $\mu_\rho\,\tilde u$,
$\mu_\rho\propto s\sqrt{1-\rho}$),样本协方差不携带尖峰、BBP 不触发;最优(LDA)检验有功率
$\Phi\!\big(\tfrac12\|\mu_\rho\|\sqrt{n}\big)$,一条\emph{解析} $\mathrm{erf}$ 曲线,对每个 $\rho<1$ 严格
高于随机:无阈值。
\end{itemize}
故悬崖是足迹\emph{二阶}结构的性质,而非部分信道本身的。
\end{theorem}

\noindent\emph{证明。} (i) 是命题~\ref{prop:wall}--\ref{prop:converse}。(ii):在已分辨均值移位下两类为
$\mathcal N(\pm\tfrac12\mu_\rho\tilde u,I_{\dmon})$;协方差未扰动,故样本协方差无尖峰、恢复问题是均值估计,其
误差为 $O(\sqrt{\dmon/n})$ 且在 $\rho$ 中光滑。Bayes 检验是沿 $\tilde u$ 的 LDA,误差概率
$\Phi(-\tfrac12\|\mu_\rho\|\sqrt n)$;因 $\|\mu_\rho\|>0$ 对所有 $\rho<1$,功率解析且无阈值。\hfill$\square$

\noindent\emph{范围。} 定理~\ref{th:dich} 是一个\emph{族内}判据:它按阶数分类部分信道的秩一扰动。它\emph{不}
断言每个"优化器 vs 检查"失败都是这两者之一。两个对照,经验展示(图~\ref{fig:classlaw},附录~\ref{app:repro}):
一个逃避为二阶的学习分类器\emph{在}族内、继承悬崖(它是 \S\ref{sec:wall} 的墙换皮);奖励模型过优化~\cite{gao}
是一个\emph{在其外}的光滑泛化误差(真值曲线先升后趋平,测得曲率 $\approx3\times10^{-4}$),由同样两个旋钮
$\sqrt{\dmon/d}$(覆盖)与 $\sqrt{\dmon/n}$(估计)支配,但带解析边缘。

\begin{remark}[重尾噪声:一条仿真支撑的鲁棒性附注]\label{rem:robust}
(i) 的悬崖在有限四阶矩下导出(使样本协方差集中)。我们记录——\emph{作为一条仿真支撑的观察而非定理}——重尾
不移除悬崖、只废掉朴素估计器。当已分辨噪声是椭圆型、四阶矩发散(Student-$t$,$\nu\le4$)时,样本协方差顶
特征向量不集中、朴素检测器在所有 $\rho$ 处失明;把它换成鲁棒二阶统计量——空间符号协方差 $x\mapsto x/\|x\|$,
其顶特征向量在椭圆模型下是总体轴的一致估计~\cite{tyler,signcov}——恢复一个随维度变尖锐的尖锐相变,在一个
移位的 $\rho^\star$ 处(图~\ref{fig:classlaw}b)。一个定理级陈述(空间符号谱在 $\nu\le4$ 下的 BBP 型阈值)
留开;此处我们只 claim 经验恢复,即失明是估计器失败、非信息论极限。
\end{remark}

\begin{figure}[htbp]\centering
\includegraphics[width=\linewidth]{classification_law.png}
\caption{\textbf{悬崖判据。} (a) 二阶(协方差尖峰)足迹在 $\rho^\star$ 处坍塌(悬崖);一阶(均值移位)足迹
平滑下降(斜坡)。(b) 重尾(Student-$t$,四阶矩发散):朴素协方差估计器在每个 $\rho$ 处失明,但一个鲁棒
(空间符号)估计器恢复一个尖锐、移位的悬崖。(c) 各"策略 vs 检查"博弈落在何处:监控、覆盖与二阶分类器是悬崖;
一阶分类器与奖励模型过优化是斜坡;重尾配朴素估计器是一个\emph{可修复}的失明,而非第三区。}
\label{fig:classlaw}
\end{figure}

\subsection*{第二把刀:承诺 vs 随机化}
定理~\ref{th:dich} 沿一条轴——足迹的\emph{阶数}——溶解悬崖。还有第二条轴:观察者能否\emph{承诺}到一个固定
子空间。纲领的开放中心(\S\ref{sec:open})正活在这条轴上,而在其上墙又是斜坡。

\begin{proposition}[随机化溶解悬崖:canonical 覆盖模型]\label{prop:coverslope}
考虑\emph{集中方向覆盖模型}:在覆盖区 $K>\dmon$,观察者无法瞄准固定子空间、须\emph{随机化}它分辨 $K$ 个被加载
方向中的哪个 $\dmon$ 维子空间(一个覆盖 / Colonel-Blotto 型博弈~\cite{blotto,lotto}),而对手把信号植入单一(最坏情形)方向。检测于是退化为组合事件"被加载方向被
观测",故检测概率等于\emph{覆盖比例}
\begin{equation}\label{eq:coverslope}
p_{\mathrm{det}}=f\equiv \dmon/K=\alpha/\kappa,
\end{equation}
\emph{在 $f$ 中线性、且与维度无关}(在 $d$ 四倍变化下验证,图~\ref{fig:coverslope}a)。命题~\ref{prop:wall} 的
BBP 悬崖在被观测子空间\emph{内部}存活——逐方向检测在尖峰强度上仍是尖锐阈值——但被平滑包络 $f$ \emph{封顶}
(图~\ref{fig:coverslope}b):复合是悬崖\,$\times$\,平滑-$f$,故在覆盖维度上是\emph{斜坡},值按
$V^\star_{\mathrm{cov}}\sim(\text{edge})/f$ 退化。集中方向是对手对观察者的最坏情形,故 \eqref{eq:coverslope} 是
canonical 实例;完整覆盖博弈(一般铺展谱、峰值/聚合 minimax)不在此声明——其精确律是开放残余
(\S\ref{sec:open})。
\end{proposition}

\noindent\emph{机制。} 定理~\ref{th:dich} 与命题~\ref{prop:coverslope} 是同一现象的两条轴:悬崖需要\emph{承诺}
——固定二阶足迹被固定分辨率观察者读取——而对任一轴平均都把阈值线性化。对信号\emph{阶数}平均(均值而非协方差)
给出定理~\ref{th:dich}(ii) 的 $\mathrm{erf}$ 斜坡;对\emph{看哪个子空间}平均(被迫随机化的观察者)给出
\eqref{eq:coverslope} 的 $f$-斜坡。于是锐化后的判据:\emph{墙是悬崖当且仅当足迹二阶\textbf{且}观察者可承诺};
失去任一——一阶线索,或被迫随机化——它就溶解成斜坡。

\noindent\emph{防守解读。} 斜坡的陡度是覆盖-任务维度比 $f=\alpha/\kappa$。随机化不是"不可防"——检测平滑、单调、
\emph{可定价}:每单位覆盖买 $f$ 的检测,没有无预警的坍塌。但维持目标检测迫使覆盖预算追踪可藏维度,$\dmon\sim K$。
当任务维度跑赢覆盖($\kappa\gg\alpha$,覆盖默认)时,$f\to0$、检测消失——不是悬崖,而是平滑退化,没有更好的检验能
修复它、只有随对手可藏维度增长的覆盖预算能。这是 tier~S:$p_{\mathrm{det}}=f$ 线性是干净的,但精确覆盖律
(斜坡的常数、以及其内部的自由卷积边缘)留开(\S\ref{sec:open})。

\begin{figure}[htbp]\centering
\includegraphics[width=\linewidth]{covering_slope.png}
\caption{\textbf{覆盖博弈是斜坡(命题~\ref{prop:coverslope})。} (a) 面对集中植入信号,检测概率恰等于覆盖比例
$f=\dmon/K$、且\emph{与维度无关}(两个维度坍到直线 $p_{\mathrm{det}}=f$ 上):观察者被迫随机化把逐方向悬崖
线性化成斜坡。(b) BBP 悬崖在被观测子空间\emph{内部}存活——检测在边缘 $\sqrt{\dmon/n}$ 处跳变、随维度变尖锐
——但被平滑覆盖包络 $f$ 封顶,故复合在覆盖维度上是斜坡。}
\label{fig:coverslope}
\end{figure}

\section{数值验证}\label{sec:numerics}
所有实验仅用 CPU(\texttt{numpy}/\texttt{scipy});脚本见附录~\ref{app:repro}。观察者把 $\hat u$ 估计为 $n$ 个
已分辨样本的样本协方差顶特征向量,并按留出会话沿 $\hat u$ 的平均能量打分;检测 AUC 为会话上的植入对干净。闭式
是被匹配的,而非拟合的。

